local Icon = Create("ImageLabel", { Size = UDim2.new(0, 20, 0, 20), AnchorPoint = Vector2.new(0.5, 0.5), Position = UDim2.new(0.5, 0, 0.5, 0), BackgroundTransparency = 1, ImageColor3 = Theme.IconActive, Parent = FloatBtn } )
ApplyIcon(Icon, iconName)

local dragging = false; local dragStart = nil; local startPos = nil
FloatBtn.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true; dragStart = input.Position; startPos = FloatBtn.Position
        end
end)
UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            FloatBtn.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
end)
FloatBtn.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
            if (input.Position - dragStart).Magnitude < 5 then
                TweenService:Create(Icon, TweenInfo.new(0.1), { Size = UDim2.new(0, 16, 0, 16) } ):Play()
                task.wait(0.1)
                TweenService:Create(Icon, TweenInfo.new(0.1), { Size = UDim2.new(0, 20, 0, 20) } ):Play()
                if callback then callback() end
            end
    end
end)

return FloatBtn
end

function SidebarAPI:SetToggleStyle(styleName)
    self.ToggleStyle = styleName
    for _, t in pairs(self.Toggles) do t.UpdateVisuals(false) end
end

function SidebarAPI:SetTheme(themeName)
    local newT = ThemeLibrary[themeName]
    if not newT then return end
    Theme.BgColor = newT.Bg; Theme.ElementBg = newT.El; Theme.Accent = newT.Ac
    local tInfo = TweenInfo.new(0.4, Enum.EasingStyle.Quint)

    for _, bg in ipairs(self.Backgrounds) do TweenService:Create(bg, tInfo, { BackgroundColor3 = Theme.BgColor } ):Play() end
    for _, el in ipairs(self.ElementBackgrounds) do TweenService:Create(el, tInfo, { BackgroundColor3 = Theme.ElementBg } ):Play() end
    for _, acc in ipairs(self.Accents) do TweenService:Create(acc, tInfo, { TextColor3 = Theme.Accent } ):Play() end
    for _, sl in ipairs(self.Sliders) do
        TweenService:Create(sl.Fill, tInfo, { BackgroundColor3 = Theme.Accent } ):Play()
        TweenService:Create(sl.ValueLabel, tInfo, { TextColor3 = Theme.Accent } ):Play()
        TweenService:Create(sl.Track, tInfo, { BackgroundColor3 = Theme.BgColor } ):Play()
    end
for _, tog in ipairs(self.Toggles) do tog.UpdateVisuals(false) end
for _, tab in ipairs(self.Tabs) do
    if tab.IsActive then TweenService:Create(tab.Indicator, tInfo, { BackgroundColor3 = Theme.Accent } ):Play() end
end
end

SidebarAPI.UpdateLayout()
return SidebarAPI
end

