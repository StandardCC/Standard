function SidebarAPI:AddTab(title, iconName)
    local BtnContainer = Create("TextButton", { BackgroundTransparency = 1, Text = "", Parent = TabContainer } )
    local Indicator = Create("Frame", { BorderSizePixel = 0, Parent = BtnContainer } )
    ApplyAccentGlass(Indicator); Create("UICorner", { CornerRadius = UDim.new(1, 0), Parent = Indicator } , { KeepRound = true } )

    local Icon = Create("ImageLabel", { Size = UDim2.new(0, 18, 0, 18), AnchorPoint = Vector2.new(0.5, 0.5), Position = UDim2.new(0.5, 0, 0.5, 0), BackgroundTransparency = 1, ImageColor3 = Theme.IconMuted, Parent = BtnContainer } )
    ApplyIcon(Icon, iconName)

    local TabPage = Create("Frame", { Name = title .. "_Page", Parent = PageContainer, Size = UDim2.new(1, 0, 1, 0), BackgroundTransparency = 1, Visible = false } )
    local PageLayout = Create("UIListLayout", { Padding = UDim.new(0, 8), SortOrder = Enum.SortOrder.LayoutOrder, HorizontalAlignment = Enum.HorizontalAlignment.Center, Parent = TabPage } )
    Create("UIPadding", { PaddingTop = UDim.new(0, 12), PaddingBottom = UDim.new(0, 12), Parent = TabPage } )

    PageLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function() PageContainer.CanvasSize = UDim2.new(0, 0, 0, PageLayout.AbsoluteContentSize.Y + 24) end)

    local TabData = { Btn = BtnContainer, Indicator = Indicator, Icon = Icon, Page = TabPage, Title = title, IconName = iconName, IsActive = false }
    table.insert(self.Tabs, TabData); self.UpdateLayout()

    BtnContainer.MouseEnter:Connect(function() if not TabData.IsActive then TweenService:Create(Icon, TweenInfo.new(0.2), { ImageColor3 = Color3.fromRGB(200, 200, 210) } ):Play() end end)
    BtnContainer.MouseLeave:Connect(function() if not TabData.IsActive then TweenService:Create(Icon, TweenInfo.new(0.2), { ImageColor3 = Theme.IconMuted } ):Play() end end)

    BtnContainer.MouseButton1Click:Connect(function()
            if self.ActiveTab == TabData then
                TabData.IsActive = false; self.ActiveTab = nil
                TweenService:Create(Icon, ANIM_INFO, { ImageColor3 = Theme.IconMuted } ):Play()
                local offSize = self.IsHorizontal and UDim2.new(0, 0, 0, 2) or UDim2.new(0, 2, 0, 0)
                TweenService:Create(Indicator, ANIM_INFO, { Size = offSize } ):Play()
                TabPage.Visible = false; ContentWindow.Visible = false
                return
            end
        if self.ActiveTab then
            self.ActiveTab.IsActive = false
            TweenService:Create(self.ActiveTab.Icon, ANIM_INFO, { ImageColor3 = Theme.IconMuted } ):Play()
            local offSize = self.IsHorizontal and UDim2.new(0, 0, 0, 2) or UDim2.new(0, 2, 0, 0)
            TweenService:Create(self.ActiveTab.Indicator, ANIM_INFO, { Size = offSize } ):Play()
            self.ActiveTab.Page.Visible = false
        end

    self.ActiveTab = TabData; TabData.IsActive = true
    TweenService:Create(Icon, ANIM_INFO, { ImageColor3 = Theme.IconActive } ):Play()
    local onSize = self.IsHorizontal and UDim2.new(0, 16, 0, 2) or UDim2.new(0, 2, 0, 16)
    TweenService:Create(Indicator, ANIM_INFO, { Size = onSize } ):Play()

    TopbarTitle.Text = TabData.Title; ApplyIcon(TopbarIcon, TabData.IconName)
    TabPage.Visible = true; ContentWindow.Visible = true
end)

return BuildElementsAPI(TabPage)
end

