function SidebarAPI.UpdateLayout()
    local numTabs = #SidebarAPI.Tabs
    local contentLen = (numTabs * 36) + (numTabs > 1 and ((numTabs - 1) * 6) or 0)
    if SidebarAPI.IsHorizontal then
        Layout.FillDirection = Enum.FillDirection.Horizontal
        Sidebar.Size = UDim2.new(0, contentLen + THICKNESS + 20, 0, THICKNESS)
        Logo.Position = UDim2.new(0, THICKNESS / 2 + 4, 0.5, 0)
        Divider.Size = UDim2.new(0, 1, 0, 16); Divider.Position = UDim2.new(0, THICKNESS + 6, 0.5, 0)
        TabContainer.Size = UDim2.new(1, - (THICKNESS + 12), 1, 0); TabContainer.Position = UDim2.new(0, THICKNESS + 12, 0, 0)
    else
    Layout.FillDirection = Enum.FillDirection.Vertical
    Sidebar.Size = UDim2.new(0, THICKNESS, 0, contentLen + THICKNESS + 20)
    Logo.Position = UDim2.new(0.5, 0, 0, THICKNESS / 2 + 4)
    Divider.Size = UDim2.new(0, 16, 0, 1); Divider.Position = UDim2.new(0.5, 0, 0, THICKNESS + 6)
    TabContainer.Size = UDim2.new(1, 0, 1, - (THICKNESS + 12)); TabContainer.Position = UDim2.new(0, 0, 0, THICKNESS + 12)
