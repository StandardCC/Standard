local function Create(className, properties, attributes)
    local instance = Instance.new(className)
    for k, v in pairs(properties) do instance[k] = v end
    if attributes then
        for k, v in pairs(attributes) do instance:SetAttribute(k, v) end
    end
return instance
end

local function ApplyIcon(imageObj, iconName)
    local icons48 = Icons["48px"]
    local found = icons48[iconName]
    if not found then
        for k, v in pairs(icons48) do
            if string.lower(k) == string.lower(iconName) then found = v break end
        end
end
if found then
    imageObj.Image = "rbxassetid://" .. tostring(found[1])
    imageObj.ImageRectSize = Vector2.new(found[2][1], found[2][2])
    imageObj.ImageRectOffset = Vector2.new(found[3][1], found[3][2])
else
imageObj.Image = ""
end
end

