local function MakeDraggable(dragArea, moveTarget, isSidebar)
    local dragging, dragInput, dragStart, startPos
    dragArea.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                dragging = true; dragStart = input.Position; startPos = moveTarget.Position
                if SidebarAPI.SnapToGrid then GridOverlay.Visible = true end
                local conn; conn = input.Changed:Connect(function()
                        if input.UserInputState == Enum.UserInputState.End then dragging = false; GridOverlay.Visible = false; if conn then conn:Disconnect() end end
                    end)
        end
end)
dragArea.InputChanged:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then dragInput = input end end)
UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local newX, newY = startPos.X.Offset + (input.Position.X - dragStart.X), startPos.Y.Offset + (input.Position.Y - dragStart.Y)
            if SidebarAPI.SnapToGrid then
                newX = math.floor(newX / SidebarAPI.GridSize + 0.5) * SidebarAPI.GridSize
                newY = math.floor(newY / SidebarAPI.GridSize + 0.5) * SidebarAPI.GridSize
            end
        moveTarget.Position = UDim2.new(startPos.X.Scale, newX, startPos.Y.Scale, newY)

        if isSidebar then
            local vp = workspace.CurrentCamera.ViewportSize; local curX, curY = moveTarget.AbsolutePosition.X, moveTarget.AbsolutePosition.Y
            local threshold = 120; local shouldBeHoriz = SidebarAPI.IsHorizontal
            if curY < threshold or (vp.Y - curY) < threshold then shouldBeHoriz = true
            elseif curX < threshold or (vp.X - curX) < threshold then shouldBeHoriz = false end
            if shouldBeHoriz ~= SidebarAPI.IsHorizontal then SidebarAPI.IsHorizontal = shouldBeHoriz; SidebarAPI.UpdateLayout() end
        end
end
end)
end

