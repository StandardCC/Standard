function Elements:AddSlider(text, min, max, default, callback)
    local Container = Create("Frame", { Size = UDim2.new(1, - 24, 0, 52), BackgroundColor3 = Theme.ElementBg, BackgroundTransparency = 0.5, Parent = ParentFrame } )
    table.insert(SidebarAPI.ElementBackgrounds, Container)
