            Parent = ScreenGui, Size = UDim2.new(0, 42, 0, 42), Position = UDim2.new(0.8, 0, 0.8, 0),
            BackgroundColor3 = Theme.BgColor, BackgroundTransparency = Theme.BgTrans, Text = "", AutoButtonColor = false
