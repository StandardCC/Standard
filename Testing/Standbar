function StandardTopBar:_setupDrag()
    local toggle = self._toggle
    local frame = self._frame
    local cfg = self._cfg
    local dragStart, startPos

    local function clampX(x)
        local vp = workspace.CurrentCamera.ViewportSize
        local half = cfg.buttonSize / 2
        local minPx = vp.X * cfg.minX + half
        local maxPx = vp.X * cfg.maxX - half
        return math.clamp(x, minPx, maxPx)
    end

local function syncFrameX()

    local vp = workspace.CurrentCamera.ViewportSize
    local togglePx = toggle.Position.X.Offset
    local scaleX = togglePx / vp.X
    frame.Position = UDim2.new(scaleX + cfg.buttonSize / 2 / vp.X, 0, 0, 65)
end

local c1 = toggle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
        or input.UserInputType == Enum.UserInputType.Touch then
            self._dragging = true
            dragStart = input.Position.X
            startPos = toggle.Position
        end
end)

local c2 = UserInputService.InputChanged:Connect(function(input)
        if not self._dragging then return end
        if input.UserInputType == Enum.UserInputType.MouseMovement
        or input.UserInputType == Enum.UserInputType.Touch then
            local delta = input.Position.X - dragStart
            local vp = workspace.CurrentCamera.ViewportSize
            local newX = clampX(startPos.X.Offset + delta)
            toggle.Position = UDim2.new(0, newX, startPos.Y.Scale, startPos.Y.Offset)
            syncFrameX()
        end
end)

local c3 = UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
        or input.UserInputType == Enum.UserInputType.Touch then
            if self._dragging then
                self._dragging = false
            end
    end
end)

table.insert(self._connections, c1)
table.insert(self._connections, c2)
table.insert(self._connections, c3)
end

function StandardTopBar:_setupToggle()
    local cfg = self._cfg

    local c = self._toggle.MouseButton1Click:Connect(function()
            if self._dragging then return end
            self:_toggle(not self._opened)
        end)
table.insert(self._connections, c)
end

function StandardTopBar:_toggle(state)
    if self._animating then return end
    self._animating = true
    self._opened = state

    local icon = self._icon
    local frame = self._frame
    local cfg = self._cfg

    local shrink = tween(icon, makeTweenInfo(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.In),
        { Size = UDim2.new(0, 0, 0, 0), Rotation = 180 } )
    shrink.Completed:Wait()

    if state then
        icon.Image = cfg.closeIcon
        icon.Rotation = - 180
        frame.Visible = true
        task.spawn(function()
                tween(frame, makeTweenInfo(0.18, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
                    { Size = UDim2.new(0, 50, 0, 50) } )
                task.wait(0.18)
                local itemCount = #self._items
                local targetW = math.min(math.max(itemCount * 55, 120), cfg.frameWidth)
                tween(frame, makeTweenInfo(0.28, Enum.EasingStyle.Quart, Enum.EasingDirection.Out),
                    { Size = UDim2.new(0, targetW, 0, cfg.frameHeight) } )
            end)
else
icon.Image = cfg.logo
icon.Rotation = - 180
task.spawn(function()
        local t = tween(frame, makeTweenInfo(0.2, Enum.EasingStyle.Quart, Enum.EasingDirection.In),
            { Size = UDim2.new(0, 0, 0, 0) } )
        t.Completed:Wait()
        frame.Visible = false
    end)
end

tween(icon, makeTweenInfo(0.28, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
    { Size = UDim2.new(0.78, 0, 0.78, 0), Rotation = 0 } )
task.wait(0.28)
self._animating = false
end

function StandardTopBar:_setupOutsideClick()
    local c = UserInputService.InputBegan:Connect(function(input, processed)
            if not self._opened or self._animating or processed or self._dragging then return end
            if input.UserInputType == Enum.UserInputType.MouseButton1
            or input.UserInputType == Enum.UserInputType.Touch then
                self:_toggle(false)
            end
    end)
table.insert(self._connections, c)
end

function StandardTopBar:_updateCanvas()
    local count = #self._items
    self._scroll.CanvasSize = UDim2.new(0, count * 55 + 8, 0, 0)
end

function StandardTopBar:AddItem(item)
    assert(type(item) == "table" and item.Text, "StandardTopBar.AddItem: item must have a .Text field")

    local cfg = self._cfg

    local btn = Instance.new("ImageButton")
    btn.Name = item.Text .. "Btn"
    btn.Size = UDim2.new(0, 46, 0, 46)
    btn.BackgroundColor3 = cfg.itemColor
    btn.BackgroundTransparency = cfg.itemAlpha
    btn.Image = item.Icon or ""
    btn.ScaleType = Enum.ScaleType.Fit
    btn.ZIndex = 9998
    btn.AutoButtonColor = false
    btn.Parent = self._scroll

    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 10)
    corner.Parent = btn

    local btnStroke = Instance.new("UIStroke")
    btnStroke.Thickness = 1
    btnStroke.Color = Color3.fromRGB(100, 100, 100)
    btnStroke.Transparency = 0.75
    btnStroke.Parent = btn

    btn.MouseEnter:Connect(function()
            tween(btn, makeTweenInfo(0.15), { BackgroundTransparency = 0.3 } )
        end)
btn.MouseLeave:Connect(function()
        tween(btn, makeTweenInfo(0.15), { BackgroundTransparency = cfg.itemAlpha } )
    end)

local warn = Instance.new("ImageLabel")
warn.Name = "Warning"
warn.Size = UDim2.new(0, 16, 0, 16)
warn.Position = UDim2.new(1, - 2, 0, 2)
warn.AnchorPoint = Vector2.new(1, 0)
warn.BackgroundTransparency = 1
warn.Image = cfg.warningIcon
warn.ZIndex = 10005
warn.Visible = false
warn.Parent = btn

local tip = Instance.new("TextLabel")
tip.Name = "Tooltip"
tip.Text = item.Text
tip.Size = UDim2.new(0, 0, 0, 20)
tip.AutomaticSize = Enum.AutomaticSize.X
tip.Position = UDim2.new(0.5, 0, 1, 5)
tip.AnchorPoint = Vector2.new(0.5, 0)
tip.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
tip.BackgroundTransparency = 0.1
tip.TextColor3 = Color3.fromRGB(220, 220, 220)
tip.TextSize = 11
tip.Font = Enum.Font.GothamMedium
tip.ZIndex = 10010
tip.Visible = false
tip.Parent = btn

local tipCorner = Instance.new("UICorner")
tipCorner.CornerRadius = UDim.new(0, 5)
tipCorner.Parent = tip

local tipPad = Instance.new("UIPadding")
tipPad.PaddingLeft = UDim.new(0, 5)
tipPad.PaddingRight = UDim.new(0, 5)
tipPad.Parent = tip

btn.MouseEnter:Connect(function() tip.Visible = true end)
btn.MouseLeave:Connect(function() tip.Visible = false end)

local loop = task.spawn(function()
        while task.wait(1.5) do
            local uiName = item.Text .. "UI"
            local found = PlayerGui:FindFirstChild(uiName) or CoreGui:FindFirstChild(uiName)
            warn.Visible = (found == nil)
        end
end)
table.insert(self._loops, loop)

btn.MouseButton1Click:Connect(function()
        local uiName = item.Text .. "UI"
        local target = PlayerGui:FindFirstChild(uiName) or CoreGui:FindFirstChild(uiName)

        local validNames = { }
        for _, it in ipairs(self._items) do validNames[it.Text .. "UI"] = true end
        for _, v in pairs(PlayerGui:GetChildren()) do
            if v:IsA("ScreenGui") and validNames[v.Name] and v.Name ~= uiName then
                v.Enabled = false
            end
    end
for _, v in pairs(CoreGui:GetChildren()) do
    if v:IsA("ScreenGui") and validNames[v.Name] and v.Name ~= uiName then
        v.Enabled = false
    end
end

if target then target.Enabled = not target.Enabled end

if self._cfg.onSelect then
    self._cfg.onSelect(item)
end

self:_toggle(false)
end)

table.insert(self._items, item)
table.insert(self._buttons, { item = item, btn = btn } )
self:_updateCanvas()
end

function StandardTopBar:RemoveItem(text)
    for i, entry in ipairs(self._buttons) do
        if entry.item.Text == text then
            entry.btn:Destroy()
            table.remove(self._buttons, i)
            break
        end
end
for i, it in ipairs(self._items) do
    if it.Text == text then
        table.remove(self._items, i)
        break
    end
end
self:_updateCanvas()
end

function StandardTopBar:SetPosition(udim2)
    self._toggle.Position = udim2
end

function StandardTopBar:SetLogo(assetId)
    self._cfg.logo = assetId
    if not self._opened then
        self._icon.Image = assetId
    end
end

function StandardTopBar:Open() self:_toggle(true) end
function StandardTopBar:Close() self:_toggle(false) end

function StandardTopBar:Destroy()
    for _, c in ipairs(self._connections) do c:Disconnect() end
    for _, l in ipairs(self._loops) do task.cancel(l) end
    if self._sg and self._sg.Parent then self._sg:Destroy() end
    self._connections = { }
    self._loops = { }
end

return StandardTopBar
