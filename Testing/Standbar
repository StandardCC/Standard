local StandardTopBar = { }
StandardTopBar.__index = StandardTopBar

local TweenService = game:GetService("TweenService")
local CoreGui = game:GetService("CoreGui")
local UserInputService = game:GetService("UserInputService")
local Player = game.Players.LocalPlayer
local PlayerGui = Player:WaitForChild("PlayerGui")

local DEFAULTS = {
    logo = "rbxassetid://85140863077888",
    closeIcon = "rbxassetid://121392148105762",
    warningIcon = "rbxassetid://103524254370228",

    minX = 0.05,
    maxX = 0.95,

    buttonSize = 44,
    buttonColor = Color3.fromRGB(10, 10, 10),
    buttonAlpha = 0.15,
    frameColor = Color3.fromRGB(15, 15, 15),
    frameAlpha = 0.08,
    itemColor = Color3.fromRGB(40, 40, 40),
    itemAlpha = 0.6,
    frameWidth = 300,
    frameHeight = 60,
}

local function tween(obj, info, props)
    local t = TweenService:Create(obj, info, props)
    t:Play()
    return t
end

local function makeTweenInfo(t, style, dir)
    return TweenInfo.new(t, style or Enum.EasingStyle.Quad, dir or Enum.EasingDirection.Out)
end

function StandardTopBar.new(config)
    config = config or { }
    local self = setmetatable( { } , StandardTopBar)

    self._cfg = setmetatable(config, { __index = DEFAULTS } )
    self._opened = false
    self._animating = false
    self._dragging = false
    self._items = { }
    self._buttons = { }
    self._connections = { }
    self._loops = { }

    self:_buildGui()
    self:_setupDrag()
    self:_setupToggle()
    self:_setupOutsideClick()

    for _, item in ipairs(config.items or { } ) do
        self:AddItem(item)
    end

return self
end

