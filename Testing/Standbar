    local toggle = Instance.new("TextButton")
    toggle.Name = "ToggleButton"
    toggle.Size = UDim2.new(0, cfg.buttonSize, 0, cfg.buttonSize)
    toggle.Position = UDim2.new(0.5, - cfg.buttonSize / 2, 0, 12)
    toggle.BackgroundColor3 = cfg.buttonColor
    toggle.BackgroundTransparency = cfg.buttonAlpha
    toggle.Text = ""
    toggle.ZIndex = 9999
    toggle.AutoButtonColor = false
    toggle.Parent = sg
    self._toggle = toggle

    local tc = Instance.new("UICorner")
    tc.CornerRadius = UDim.new(1, 0)
    tc.Parent = toggle

    local stroke = Instance.new("UIStroke")
    stroke.Thickness = 1
    stroke.Color = Color3.fromRGB(80, 80, 80)
    stroke.Transparency = 0.6
    stroke.Parent = toggle

    local icon = Instance.new("ImageLabel")
    icon.Name = "Icon"
    icon.Size = UDim2.new(0.78, 0, 0.78, 0)
    icon.AnchorPoint = Vector2.new(0.5, 0.5)
    icon.Position = UDim2.new(0.5, 0, 0.5, 0)
    icon.BackgroundTransparency = 1
    icon.Image = cfg.logo
    icon.ScaleType = Enum.ScaleType.Fit
    icon.ZIndex = 10000
    icon.Parent = toggle
    self._icon = icon

    local dragHint = Instance.new("Frame")
    dragHint.Name = "DragHint"
    dragHint.Size = UDim2.new(0, 16, 0, 4)
    dragHint.Position = UDim2.new(0.5, - 8, 1, 6)
    dragHint.BackgroundColor3 = Color3.fromRGB(180, 180, 180)
    dragHint.BackgroundTransparency = 0.6
    dragHint.BorderSizePixel = 0
    dragHint.ZIndex = 9999
    dragHint.Parent = toggle

    local dhc = Instance.new("UICorner")
    dhc.CornerRadius = UDim.new(1, 0)
    dhc.Parent = dragHint

    local frame = Instance.new("Frame")
    frame.Name = "MainFrame"
    frame.Size = UDim2.new(0, 0, 0, 0)
    frame.Position = UDim2.new(0.5, 0, 0, 65)
    frame.AnchorPoint = Vector2.new(0.5, 0)
    frame.BackgroundColor3 = cfg.frameColor
    frame.BackgroundTransparency = cfg.frameAlpha
    frame.Visible = false
    frame.ClipsDescendants = true
    frame.ZIndex = 9998
    frame.Parent = sg
    self._frame = frame

    local fc = Instance.new("UICorner")
    fc.CornerRadius = UDim.new(0, 12)
    fc.Parent = frame

    local fstroke = Instance.new("UIStroke")
    fstroke.Thickness = 1
